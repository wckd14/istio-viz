{
  "name": "istio-viz",
  "version": "0.1.0",
  "description": "Visualize effective Istio L7 routing topology from Gateway/VirtualService/Service/DestinationRule manifests",
  "license": "MIT",
  "author": "wckd14",
  "repository": {
    "type": "git",
    "url": "https://github.com/wckd14/istio-viz.git"
  },
  "homepage": "https://github.com/wckd14/istio-viz#readme",
  "bugs": "https://github.com/wckd14/istio-viz/issues",
  "keywords": ["istio", "kubernetes", "service-mesh", "visualization", "routing", "virtualservice", "gateway"],
  "type": "module",
  "bin": {
    "istio-viz": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild dist/index.js --bundle --platform=node --outfile=dist/bundle.cjs --format=cjs --external:@resvg/resvg-js",
    "test": "tsc --noEmit && node --import tsx --test \"test/**/*.test.ts\"",
    "dev": "node --import tsx src/index.ts"
  },
  "pkg": {
    "scripts": "dist/bundle.cjs",
    "targets": [
      "node22-linux-x64",
      "node22-linux-arm64",
      "node22-macos-x64",
      "node22-macos-arm64",
      "node22-win-x64"
    ],
    "outputPath": "release/"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.6.0"
  },
  "optionalDependencies": {
    "@resvg/resvg-js": "^2.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@yao-pkg/pkg": "^6.20.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
